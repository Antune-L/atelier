{
  "name": "kanban-agents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:web": "vite --config src/web/vite.config.ts",
    "real": "concurrently -n server,web -c blue,magenta \"bun run real:server\" \"bun run real:web\"",
    "real:server": "KANBAN_SETUP=1 KANBAN_DRY_RUN=0 KANBAN_DB=kanban-real.db bun src/server/index.ts",
    "real:web": "vite build --config src/web/vite.config.ts && vite preview --config src/web/vite.config.ts",
    "proxy": "sudo --preserve-env=DEV_HOST \"$(command -v caddy)\" start --config ./Caddyfile --adapter caddyfile",
    "proxy:stop": "sudo \"$(command -v caddy)\" stop",
    "dev:proxy": "bun run proxy; bun run dev",
    "real:proxy": "bun run proxy; bun run real",
    "start": "bun src/server/index.ts",
    "start:prod": "bun run build:web && bun start",
    "build:web": "vite build --config src/web/vite.config.ts",
    "build:desktop": "bun run build:web && electrobun build",
    "dev:desktop": "bun run build:web && KANBAN_REPO_ROOT=\"$PWD\" electrobun dev",
    "link:desktop-data": "DATA=\"$HOME/Library/Application Support/kanban-agents\"; mkdir -p \"$DATA\" uploads && rm -f \"$DATA/config.json\" \"$DATA/kanban.db\" \"$DATA/kanban.db-wal\" \"$DATA/kanban.db-shm\" && rm -rf \"$DATA/uploads\" && ln -s \"$PWD/config.json\" \"$DATA/config.json\" && ln -s \"$PWD/kanban-real.db\" \"$DATA/kanban.db\" && ln -s \"$PWD/uploads\" \"$DATA/uploads\" && echo \"Linked desktop data to repo: config.json + kanban-real.db + uploads/\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.193",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.4.10",
    "elysia": "^1.1.27",
    "marked": "^18.0.5",
    "nanoid": "^5.0.9",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.11.2",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "zod": "^4"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/bun": "^1.1.14",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "electrobun": "1.18.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "lucide-react": "^0.469.0",
    "postcss": "^8.4.49",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
